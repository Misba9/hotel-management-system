{
  "name": "@nausheen/customer-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "clean:hard": "npm run clean && rm -rf .turbo",
    "free-port": "node ./scripts/free-dev-port.mjs",
    "dev": "next dev -p 3000",
    "dev:clean": "npm run clean && next dev -p 3000",
    "dev:hard": "npm run clean:hard && next dev -p 3000",
    "dev:reset": "npm run free-port && npm run clean && next dev -p 3000",
    "recover:chunks": "npm run free-port && npm run clean && npm run build && next dev -p 3000",
    "reinstall": "npm run clean && rm -rf node_modules && npm install",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "start": "next start -p 3000",
    "engines:peek": "npm ls next react react-dom --depth=0",
    "lint": "next lint"
  },
  "dependencies": {
    "@firebase/database": "^1.1.2",
    "@hookform/resolvers": "^3.9.0",
    "@next/env": "14.2.35",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-google-maps/api": "^2.20.8",
    "@swc/helpers": "0.5.5",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.453.0",
    "next": "^14.2.35",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "styled-jsx": "^5.1.1",
    "tailwind-merge": "^2.5.2",
    "twilio": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
