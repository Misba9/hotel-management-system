# Twilio SMS OTP (required for customer-mobile "Send OTP")
# Get values from Twilio Console → Account → API Keys / Phone Numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Must be a real Twilio SMS-capable number in E.164, e.g. +14155552671
TWILIO_SMS_FROM=
# Optional WhatsApp fallback (same Twilio account)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional OTP hash salt
# SMS_OTP_SECRET=
