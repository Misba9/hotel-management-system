rules_version = '2';
// App Check: turn on enforcement in Firebase Console (Build → App Check) for Firestore, Auth, and Functions.
// Callable/HTTP enforcement: set env FIREBASE_FUNCTIONS_ENFORCE_APP_CHECK=true on Functions after all clients use App Check.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthed() && request.auth.token.role == role;
    }

    function hasAnyRole(roles) {
      return isAuthed() && request.auth.token.role in roles;
    }

    /** Staff app RBAC uses `delivery`; legacy tokens may use `delivery_boy`. */
    function staffDeliveryAgent() {
      return hasAnyRole(["delivery_boy", "delivery"]);
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function hasOnlyKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    /** One-time mobile self-signup: exact shape, role staff, inactive until admin assigns role. */
    function validStaffSelfSignupCreate() {
      return request.resource.data.keys().hasOnly([
            "uid",
            "email",
            "name",
            "role",
            "isActive",
            "pendingApproval",
            "phone",
            "createdAt"
          ]) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email is string &&
        request.resource.data.name is string &&
        request.resource.data.role == "staff" &&
        request.resource.data.isActive == false &&
        request.resource.data.pendingApproval == true &&
        request.resource.data.phone is string &&
        request.resource.data.createdAt is timestamp;
    }

    /** First staff-app login: `staff_users/{auth.uid}` — pending role; `isActive` may be true (app) or false. */
    function validPendingStaffProfileCreate() {
      return request.resource.data.keys().hasOnly([
            "uid",
            "email",
            "name",
            "role",
            "isActive",
            "createdAt"
          ]) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email is string &&
        request.resource.data.name is string &&
        request.resource.data.role == "pending" &&
        request.resource.data.isActive is bool &&
        request.resource.data.createdAt == request.time;
    }

    /** Owner may create their doc if staff self-signup shape, or a profile without privileged staff fields. */
    function usersOwnerCreateAllowed(userId) {
      return isOwner(userId) && (
          validStaffSelfSignupCreate() ||
          !request.resource.data.keys().hasAny(["role", "approved", "pendingApproval", "isActive", "status"])
        );
    }

    /** Owner may patch name/phone/etc. but cannot change role, approval flags, or staff activation (e.g. waiter → kitchen). */
    function usersOwnerUpdateAllowed(userId) {
      return isOwner(userId) &&
        !request.resource.data.diff(resource.data).changedKeys().hasAny([
          "role",
          "approved",
          "pendingApproval",
          "isActive",
          "status"
        ]);
    }

    function validOrderStatus(status) {
      return status in ["created", "confirmed", "pending", "accepted", "rejected", "preparing", "ready", "out_for_delivery", "delivered", "cancelled"];
    }

    function validOrderWrite() {
      return request.resource.data.id is string &&
        request.resource.data.userId is string &&
        request.resource.data.branchId is string &&
        request.resource.data.orderType in ["delivery", "pickup", "dine_in"] &&
        request.resource.data.paymentMethod in ["upi", "card", "cod"] &&
        validOrderStatus(request.resource.data.status) &&
        request.resource.data.subtotal is number &&
        request.resource.data.subtotal >= 0 &&
        request.resource.data.discount is number &&
        request.resource.data.discount >= 0 &&
        request.resource.data.deliveryFee is number &&
        request.resource.data.deliveryFee >= 0 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0;
    }

    function staffUserActive() {
      return exists(/databases/$(database)/documents/staff_users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/staff_users/$(request.auth.uid)).data.isActive == true;
    }

    /** Kitchen/delivery pipeline: legacy `staff_pos`, or staff-origin tickets (`createdByUid`), or legacy staff rows without `subtotal`. */
    function usesKitchenDeliveryPipeline(data) {
      return (data.keys().hasAny(["orderKind"]) && data.orderKind == "staff_pos") ||
        (data.assignedTo is map && (
          !data.keys().hasAny(["subtotal"]) ||
          data.keys().hasAny(["createdByUid"])
        ));
    }

    /** Cashier — unified POS create. */
    function validUnifiedCashierOrderCreate(orderId) {
      return request.resource.data.keys().hasOnly([
            "id",
            "userId",
            "branchId",
            "items",
            "total",
            "subtotal",
            "tax",
            "invoiceId",
            "status",
            "createdAt",
            "updatedAt",
            "assignedTo",
            "customer",
            "createdByUid",
            "deliveryLocation"
          ]) &&
        request.resource.data.id == orderId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.branchId is string &&
        request.resource.data.status == "pending" &&
        request.resource.data.items is list &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.subtotal is number &&
        request.resource.data.subtotal >= 0 &&
        request.resource.data.tax is number &&
        request.resource.data.tax >= 0 &&
        request.resource.data.invoiceId == orderId &&
        request.resource.data.assignedTo is map &&
        request.resource.data.assignedTo.keys().hasOnly(["kitchenId", "deliveryId"]) &&
        request.resource.data.assignedTo.kitchenId is string &&
        request.resource.data.assignedTo.deliveryId is string &&
        request.resource.data.customer is map &&
        request.resource.data.deliveryLocation is map &&
        request.resource.data.deliveryLocation.lat is number &&
        request.resource.data.deliveryLocation.lng is number &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;
    }

    /** Waiter — table service order (TableOrderScreen). */
    function validWaiterTableOrderCreate(orderId) {
      return request.resource.data.keys().hasOnly([
            "id",
            "userId",
            "createdByUid",
            "tableNumber",
            "tableId",
            "orderType",
            "items",
            "totalAmount",
            "status",
            "paymentStatus",
            "createdAt"
          ]) &&
        request.resource.data.id == orderId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.tableNumber is number &&
        request.resource.data.tableId is string &&
        request.resource.data.tableId != "" &&
        request.resource.data.orderType == "table" &&
        request.resource.data.items is list &&
        request.resource.data.totalAmount is number &&
        request.resource.data.totalAmount >= 0 &&
        request.resource.data.status == "PLACED" &&
        request.resource.data.paymentStatus == "PENDING" &&
        request.resource.data.createdAt is timestamp;
    }

    /** Waiter — dine-in ticket. */
    function validUnifiedWaiterOrderCreate(orderId) {
      return request.resource.data.keys().hasOnly([
            "id",
            "userId",
            "branchId",
            "orderType",
            "type",
            "tableNumber",
            "items",
            "total",
            "subtotal",
            "tax",
            "invoiceId",
            "createdByUid",
            "status",
            "createdAt",
            "updatedAt",
            "assignedTo"
          ]) &&
        request.resource.data.id == orderId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.branchId is string &&
        request.resource.data.orderType == "dine_in" &&
        request.resource.data.status == "pending" &&
        request.resource.data.items is list &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.subtotal is number &&
        request.resource.data.subtotal >= 0 &&
        request.resource.data.tax is number &&
        request.resource.data.tax >= 0 &&
        request.resource.data.invoiceId == orderId &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.tableNumber is int &&
        request.resource.data.assignedTo is map &&
        request.resource.data.assignedTo.keys().hasOnly(["kitchenId", "deliveryId"]) &&
        request.resource.data.assignedTo.kitchenId is string &&
        request.resource.data.assignedTo.deliveryId is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;
    }

    function assignDeliveryUid(data) {
      return (data.assignedTo.deliveryId is string && data.assignedTo.deliveryId != "")
        ? data.assignedTo.deliveryId
        : data.assignedTo.delivery;
    }

    function pipelineChangedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function pipelineKitchenUpdateOk() {
      return hasRole("kitchen_staff") &&
        staffUserActive() &&
        usesKitchenDeliveryPipeline(resource.data) &&
        pipelineChangedKeys().hasOnly(["status", "updatedAt", "assignedTo"]) &&
        validOrderStatus(request.resource.data.status) &&
        (
          (resource.data.status == "pending" && request.resource.data.status == "accepted") ||
          (resource.data.status == "pending" && request.resource.data.status == "preparing") ||
          (resource.data.status == "accepted" && request.resource.data.status == "preparing") ||
          (resource.data.status == "preparing" && request.resource.data.status == "ready")
        );
    }

    function pipelineDeliveryUpdateOk() {
      return staffDeliveryAgent() &&
        staffUserActive() &&
        usesKitchenDeliveryPipeline(resource.data) &&
        pipelineChangedKeys().hasOnly(["status", "updatedAt", "assignedTo", "riderId"]) &&
        validOrderStatus(request.resource.data.status) &&
        (
          (
            resource.data.status == "ready" &&
            request.resource.data.status == "out_for_delivery" &&
            assignDeliveryUid(request.resource.data) == request.auth.uid &&
            (
              !("riderId" in request.resource.data) ||
              request.resource.data.riderId == request.auth.uid
            )
          ) ||
          (
            resource.data.status == "out_for_delivery" &&
            request.resource.data.status == "delivered" &&
            assignDeliveryUid(resource.data) == request.auth.uid
          )
        );
    }

    function pipelineManagerUpdateOk() {
      return hasAnyRole(["manager", "admin"]) &&
        staffUserActive() &&
        usesKitchenDeliveryPipeline(resource.data) &&
        pipelineChangedKeys().hasOnly(["status", "updatedAt", "assignedTo", "riderId", "customer", "deliveryLocation", "riderLocation"]) &&
        validOrderStatus(request.resource.data.status);
    }

    /** Live GPS while order is out for delivery (does not change drop-off). */
    function pipelineRiderLocationUpdateOk() {
      return staffDeliveryAgent() &&
        staffUserActive() &&
        usesKitchenDeliveryPipeline(resource.data) &&
        resource.data.status == "out_for_delivery" &&
        assignDeliveryUid(resource.data) == request.auth.uid &&
        pipelineChangedKeys().hasOnly(["riderLocation", "updatedAt"]) &&
        request.resource.data.riderLocation is map &&
        request.resource.data.riderLocation.lat is number &&
        request.resource.data.riderLocation.lng is number;
    }

    function validMenuItemWrite() {
      return request.resource.data.id is string &&
        request.resource.data.name is string &&
        request.resource.data.price is number &&
        request.resource.data.price >= 0 &&
        request.resource.data.available is bool;
    }

    function validPaymentWrite() {
      return request.resource.data.id is string &&
        request.resource.data.orderId is string &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        request.resource.data.status in ["pending", "paid", "failed", "refunded"];
    }

    /** Dine-in lifecycle ticket on `orders` (no `userId` / `branchId` / pipeline fields). */
    function isRestaurantLifecycleOrderDoc(data) {
      return data.keys().hasAll([
            "id",
            "tableNumber",
            "items",
            "total",
            "status",
            "paymentStatus",
            "tokenNumber",
            "createdAt"
          ]) &&
        data.status in ["pending", "preparing", "ready", "served"] &&
        data.paymentStatus in ["pending", "paid"] &&
        !data.keys().hasAny(["userId", "branchId", "orderType", "assignedTo"]);
    }

    function validRestaurantLifecycleOrderCreate(orderId) {
      return request.resource.data.keys().hasOnly([
            "id",
            "tableNumber",
            "items",
            "total",
            "status",
            "paymentStatus",
            "tokenNumber",
            "createdAt",
            "updatedAt"
          ]) &&
        request.resource.data.id == orderId &&
        request.resource.data.tableNumber is int &&
        request.resource.data.tableNumber >= 0 &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.items.size() <= 200 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.status == "pending" &&
        request.resource.data.paymentStatus == "pending" &&
        request.resource.data.tokenNumber is int &&
        request.resource.data.tokenNumber >= 0 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function restaurantLifecycleKitchenUpdateOk() {
      return hasAnyRole(["kitchen_staff", "kitchen"]) &&
        staffUserActive() &&
        isRestaurantLifecycleOrderDoc(resource.data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.status in ["pending", "preparing", "ready", "served"] &&
        request.resource.data.paymentStatus == resource.data.paymentStatus &&
        request.resource.data.tokenNumber == resource.data.tokenNumber &&
        request.resource.data.tableNumber == resource.data.tableNumber &&
        request.resource.data.items == resource.data.items &&
        request.resource.data.total == resource.data.total &&
        (
          (resource.data.status == "pending" && request.resource.data.status == "preparing") ||
          (resource.data.status == "preparing" && request.resource.data.status == "ready")
        );
    }

    function restaurantLifecycleWaiterUpdateOk() {
      return hasRole("waiter") &&
        staffUserActive() &&
        isRestaurantLifecycleOrderDoc(resource.data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.status in ["pending", "preparing", "ready", "served"] &&
        request.resource.data.paymentStatus == resource.data.paymentStatus &&
        request.resource.data.tokenNumber == resource.data.tokenNumber &&
        request.resource.data.tableNumber == resource.data.tableNumber &&
        request.resource.data.items == resource.data.items &&
        request.resource.data.total == resource.data.total &&
        resource.data.status == "ready" &&
        request.resource.data.status == "served";
    }

    /** Waiter accepts ticket from `pending` → `preparing` (same as kitchen first hop). */
    function restaurantLifecycleWaiterAcceptUpdateOk() {
      return hasRole("waiter") &&
        staffUserActive() &&
        isRestaurantLifecycleOrderDoc(resource.data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.status in ["pending", "preparing", "ready", "served"] &&
        request.resource.data.paymentStatus == resource.data.paymentStatus &&
        request.resource.data.tokenNumber == resource.data.tokenNumber &&
        request.resource.data.tableNumber == resource.data.tableNumber &&
        request.resource.data.items == resource.data.items &&
        request.resource.data.total == resource.data.total &&
        resource.data.status == "pending" &&
        request.resource.data.status == "preparing";
    }

    function restaurantLifecycleCashierPaymentUpdateOk() {
      return hasRole("cashier") &&
        staffUserActive() &&
        isRestaurantLifecycleOrderDoc(resource.data) &&
        resource.data.status == "served" &&
        resource.data.paymentStatus == "pending" &&
        request.resource.data.paymentStatus == "paid" &&
        request.resource.data.status == "served" &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["paymentStatus", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.tokenNumber == resource.data.tokenNumber &&
        request.resource.data.tableNumber == resource.data.tableNumber &&
        request.resource.data.items == resource.data.items &&
        request.resource.data.total == resource.data.total;
    }

    function validStaffUserCreate(uid) {
      return request.resource.data.keys().hasOnly(["uid", "name", "role", "createdAt", "updatedAt"]) &&
        request.resource.data.uid == uid &&
        request.resource.data.uid is string &&
        request.resource.data.name is string &&
        request.resource.data.role is string &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function validStaffUserUpdate(uid) {
      return request.resource.data.uid == uid &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "role", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.name is string &&
        request.resource.data.role is string;
    }

    function validDeliveryCreate() {
      return request.resource.data.keys().hasOnly([
            "orderId",
            "customerName",
            "mobile",
            "address",
            "status",
            "deliveryBoyId",
            "createdAt",
            "updatedAt"
          ]) &&
        request.resource.data.orderId is string &&
        request.resource.data.customerName is string &&
        request.resource.data.mobile is string &&
        request.resource.data.address is string &&
        request.resource.data.status == "assigned" &&
        (
          request.resource.data.deliveryBoyId == null ||
          (request.resource.data.deliveryBoyId is string && request.resource.data.deliveryBoyId != "")
        ) &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function deliveryRiderProgressUpdateOk() {
      return hasAnyRole(["delivery_boy", "delivery"]) &&
        staffUserActive() &&
        resource.data.deliveryBoyId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.orderId == resource.data.orderId &&
        request.resource.data.customerName == resource.data.customerName &&
        request.resource.data.mobile == resource.data.mobile &&
        request.resource.data.address == resource.data.address &&
        request.resource.data.deliveryBoyId == resource.data.deliveryBoyId &&
        (
          (resource.data.status == "assigned" && request.resource.data.status == "picked") ||
          (resource.data.status == "picked" && request.resource.data.status == "delivered")
        );
    }

    function deliveryManagerPatchOk() {
      return hasAnyRole(["manager", "admin"]) &&
        staffUserActive() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "deliveryBoyId",
          "status",
          "updatedAt"
        ]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.orderId == resource.data.orderId &&
        request.resource.data.customerName == resource.data.customerName &&
        request.resource.data.mobile == resource.data.mobile &&
        request.resource.data.address == resource.data.address &&
        request.resource.data.status in ["assigned", "picked", "delivered"];
    }

    function validPrinterCreate() {
      return request.resource.data.keys().hasOnly(["name", "type", "ipAddress", "createdAt", "updatedAt"]) &&
        request.resource.data.name is string &&
        request.resource.data.type in ["wifi", "bluetooth"] &&
        request.resource.data.ipAddress is string &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function validPrinterUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "type", "ipAddress", "updatedAt"]) &&
        request.resource.data.name is string &&
        request.resource.data.type in ["wifi", "bluetooth"] &&
        request.resource.data.ipAddress is string &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    /** Monotonic order token counter (`nextToken`) — incremented by waiter POS. */
    match /appMeta/{docId} {
      allow read: if staffUserActive() &&
        hasAnyRole(["waiter", "cashier", "kitchen", "kitchen_staff", "manager", "admin"]);
      allow create: if docId == "orderToken" &&
        staffUserActive() &&
        hasAnyRole(["waiter", "manager", "admin"]) &&
        request.resource.data.keys().hasOnly(["nextToken", "updatedAt"]) &&
        request.resource.data.nextToken is int &&
        request.resource.data.nextToken >= 1 &&
        request.resource.data.nextToken <= 999999 &&
        request.resource.data.updatedAt == request.time;
      allow update: if docId == "orderToken" &&
        staffUserActive() &&
        hasAnyRole(["waiter", "manager", "admin"]) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["nextToken", "updatedAt"]) &&
        request.resource.data.nextToken is int &&
        request.resource.data.nextToken == resource.data.nextToken + 1 &&
        request.resource.data.updatedAt == request.time;
      allow delete: if false;
    }

    match /users/{userId} {
      /**
       * TEMP: permissive while debugging client address/profile writes on `users/{userId}`.
       * Replace with owner/admin rules below before production.
       */
      allow read, write: if true;

      /** Customer delivery addresses subcollection (legacy / some clients). */
      match /addresses/{addressId} {
        allow read, create, update, delete: if isAuthed() && request.auth.uid == userId;
      }
    }

    /**
     * Customer directory: customer app mirrors `users/*` + saved addresses here for admin list/search.
     * Staff dashboard reads with `role` claim; customers read/write only their own doc.
     */
    match /customers/{userId} {
      allow read: if isOwner(userId) ||
        hasAnyRole(["admin", "manager", "kitchen", "cashier", "waiter", "delivery"]);
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) &&
        request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    match /roles/{roleId} {
      allow read: if isAuthed();
      allow write: if hasRole("admin");
    }

    match /menu_categories/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]);
    }

    match /menu_items/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]) && validMenuItemWrite();
    }

    /** Waiter table orders — same shape as `menu_items` (name, price, available). */
    match /menu/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]) && validMenuItemWrite();
    }

    /** Waiter: request bill only after food is served (`status == SERVED`, payment still PENDING). */
    function waiterTableOrderBillRequestUpdate() {
      return hasRole("waiter") &&
        staffUserActive() &&
        resource.data.orderType == "table" &&
        resource.data.status == "SERVED" &&
        resource.data.paymentStatus == "PENDING" &&
        request.resource.data.paymentStatus == "REQUESTED" &&
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["paymentStatus", "updatedAt"]) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["paymentStatus"])
        );
    }

    /** Cashier: request bill when payment is still PENDING (e.g. served, waiter did not request). */
    function cashierTableOrderBillRequestUpdate() {
      return hasRole("cashier") &&
        staffUserActive() &&
        resource.data.orderType == "table" &&
        resource.data.paymentStatus == "PENDING" &&
        request.resource.data.paymentStatus == "REQUESTED" &&
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["paymentStatus", "updatedAt"]) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["paymentStatus"])
        );
    }

    /**
     * Cashier: record payment — COMPLETED + PAID.
     * Allowed when bill was REQUESTED, or table is SERVED with payment still PENDING.
     */
    function cashierCompleteTableOrderPayment() {
      return hasRole("cashier") &&
        staffUserActive() &&
        resource.data.orderType == "table" &&
        request.resource.data.status == "COMPLETED" &&
        request.resource.data.paymentStatus == "PAID" &&
        (
          resource.data.paymentStatus == "REQUESTED" ||
          (resource.data.status == "SERVED" && resource.data.paymentStatus == "PENDING")
        ) &&
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "paymentStatus", "updatedAt"]) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "paymentStatus"])
        );
    }

    /** Waiter: table ticket READY → SERVED (after kitchen marks ready). */
    function waiterTableOrderMarkServedUpdate() {
      return hasRole("waiter") &&
        staffUserActive() &&
        resource.data.orderType == "table" &&
        resource.data.status == "READY" &&
        request.resource.data.status == "SERVED" &&
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"])
        );
    }

    /** Kitchen: table tickets PLACED → PREPARING → READY (Auth claim may be `kitchen_staff`). */
    function kitchenTableOrderProgressUpdate() {
      return hasAnyRole(["kitchen_staff", "kitchen"]) &&
        staffUserActive() &&
        resource.data.orderType == "table" &&
        (
          (resource.data.status == "PLACED" && request.resource.data.status == "PREPARING") ||
          (resource.data.status == "PREPARING" && request.resource.data.status == "READY")
        ) &&
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) ||
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"])
        );
    }

    match /orders/{orderId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        hasAnyRole(["admin", "manager"]) ||
        (staffUserActive() && hasAnyRole(["kitchen_staff", "waiter", "cashier", "delivery_boy", "delivery"]))
      );
      allow create: if isAuthed() && (
        (request.resource.data.userId == request.auth.uid && validOrderWrite()) ||
        (hasRole("cashier") && staffUserActive() && validUnifiedCashierOrderCreate(orderId)) ||
        (hasRole("waiter") && staffUserActive() && validUnifiedWaiterOrderCreate(orderId)) ||
        (hasRole("waiter") && staffUserActive() && validWaiterTableOrderCreate(orderId)) ||
        (staffUserActive() &&
          hasAnyRole(["waiter", "cashier", "manager", "admin"]) &&
          validRestaurantLifecycleOrderCreate(orderId))
      );
      allow update: if isAuthed() && (
        restaurantLifecycleKitchenUpdateOk() ||
        restaurantLifecycleWaiterAcceptUpdateOk() ||
        restaurantLifecycleWaiterUpdateOk() ||
        restaurantLifecycleCashierPaymentUpdateOk() ||
        kitchenTableOrderProgressUpdate() ||
        waiterTableOrderBillRequestUpdate() ||
        waiterTableOrderMarkServedUpdate() ||
        cashierTableOrderBillRequestUpdate() ||
        cashierCompleteTableOrderPayment() ||
        (usesKitchenDeliveryPipeline(resource.data) && staffUserActive() && (
            pipelineKitchenUpdateOk() ||
            pipelineDeliveryUpdateOk() ||
            pipelineRiderLocationUpdateOk() ||
            pipelineManagerUpdateOk()
          )) ||
        (!usesKitchenDeliveryPipeline(resource.data) && hasAnyRole(["kitchen_staff", "waiter", "cashier", "manager", "admin", "delivery_boy", "delivery"]) && validOrderWrite())
      );
    }

    /** Bill / receipt — doc id == `orderId`; written with staff POS or Admin SDK (storefront). */
    function validStaffInvoiceCreate(invoiceId) {
      return request.resource.data.keys().hasOnly([
            "orderId",
            "invoiceId",
            "userId",
            "items",
            "subtotal",
            "tax",
            "total",
            "createdAt",
            "source"
          ]) &&
        request.resource.data.orderId == invoiceId &&
        request.resource.data.invoiceId == invoiceId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.subtotal is number &&
        request.resource.data.subtotal >= 0 &&
        request.resource.data.tax is number &&
        request.resource.data.tax >= 0 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.items is list &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.source in ["pos", "dine_in"];
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        hasAnyRole(["admin", "manager"]) ||
        (staffUserActive() && hasAnyRole(["kitchen_staff", "waiter", "cashier", "delivery_boy", "delivery"]))
      );
      allow create: if staffUserActive() &&
        validStaffInvoiceCreate(invoiceId) &&
        (
          (hasRole("cashier") && request.resource.data.source == "pos") ||
          (hasRole("waiter") && request.resource.data.source == "dine_in")
        );
      allow update, delete: if false;
    }

    match /order_items/{id} {
      allow read: if isAuthed();
      allow write: if hasAnyRole(["cashier", "manager", "admin"]) || isAuthed();
    }

    match /payments/{id} {
      allow read: if isAuthed();
      allow write: if hasAnyRole(["cashier", "manager", "admin"]) && validPaymentWrite();
    }

    match /addresses/{id} {
      allow read, write: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
    }

    match /delivery_assignments/{id} {
      allow read: if isAuthed();
      allow update: if hasAnyRole(["delivery_boy", "delivery", "manager", "admin"]);
      allow create: if hasAnyRole(["manager", "admin"]);
    }

    match /staff/{id} {
      allow read: if hasAnyRole(["manager", "admin"]);
      allow write: if hasAnyRole(["manager", "admin"]);
    }

    /**
     * Staff directory (TEMP): any signed-in user may read/write `staff_users` — tighten before production.
     * Admin dashboard still uses Admin SDK for other users. Replace with owner-only rules when stable.
     */
    match /staff_users/{uid} {
      allow read, write: if request.auth != null;
    }

    /**
     * Staff roster (canonical shape): `uid`, `name`, `role` — timestamps via `serverTimestamp()`.
     * Use Admin or manager tooling to keep `staffUsers` in sync with `staff_users` during migration if needed.
     */
    match /staffUsers/{uid} {
      allow read: if isAuthed() && (
        request.auth.uid == uid ||
        hasAnyRole(["admin", "manager", "kitchen", "kitchen_staff", "cashier", "waiter", "delivery_boy", "delivery"])
      );
      allow create: if hasAnyRole(["admin", "manager"]) && (hasRole("admin") || staffUserActive()) && validStaffUserCreate(uid);
      allow update: if hasAnyRole(["admin", "manager"]) && (hasRole("admin") || staffUserActive()) && validStaffUserUpdate(uid);
      allow delete: if hasRole("admin");
    }

    match /inventory/{id} {
      allow read: if hasAnyRole(["manager", "admin", "kitchen_staff"]);
      allow write: if hasAnyRole(["manager", "admin", "kitchen_staff"]);
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]);
    }

    match /notifications/{id} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, delete: if hasAnyRole(["manager", "admin"]);
      allow update: if isAuthed() && resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['seen']);
    }

    match /branches/{id} {
      allow read: if true;
      allow write: if hasRole("admin");
    }

    // v1 backend collections
    match /products/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]) &&
        request.resource.data.id is string &&
        request.resource.data.name is string &&
        request.resource.data.price is number &&
        request.resource.data.price >= 0 &&
        request.resource.data.category is string &&
        request.resource.data.image is string &&
        request.resource.data.availability is bool;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if hasAnyRole(["manager", "admin"]) &&
        request.resource.data.id is string &&
        request.resource.data.name is string &&
        request.resource.data.active is bool;
    }

    match /orderItems/{id} {
      allow read: if isAuthed();
      allow write: if hasAnyRole(["cashier", "manager", "admin"]) || isAuthed();
    }

    match /delivery/{id} {
      allow read: if isAuthed();
      allow write: if hasAnyRole(["delivery_boy", "delivery", "manager", "admin"]);
    }

    /** Customer may read a delivery row when they own the linked `orders/{orderId}` (tracker + chat). */
    function deliveryCustomerOwnsOrder(deliveryId) {
      let d = get(/databases/$(database)/documents/deliveries/$(deliveryId)).data;
      return d.keys().hasAll(["orderId"]) &&
        d.orderId is string &&
        exists(/databases/$(database)/documents/orders/$(d.orderId)) &&
        get(/databases/$(database)/documents/orders/$(d.orderId)).data.userId == request.auth.uid;
    }

    /** Outbound delivery runs (restaurant schema) — `deliveryBoyId` = rider uid when assigned. */
    match /deliveries/{deliveryId} {
      allow read: if isAuthed() && (
        hasAnyRole(["admin", "manager", "cashier", "delivery_boy", "delivery"]) ||
        resource.data.deliveryBoyId == request.auth.uid ||
        deliveryCustomerOwnsOrder(deliveryId)
      );
      allow create: if staffUserActive() && hasAnyRole(["manager", "admin", "cashier"]) && validDeliveryCreate();
      allow update: if isAuthed() && (
        deliveryRiderProgressUpdateOk() ||
        deliveryManagerPatchOk()
      );
      allow delete: if hasRole("admin");

      /** Basic rider ↔ store thread (rider is assignee on parent delivery). */
      match /messages/{msgId} {
        function deliveryThreadParticipant() {
          return exists(/databases/$(database)/documents/deliveries/$(deliveryId)) &&
            get(/databases/$(database)/documents/deliveries/$(deliveryId)).data.deliveryBoyId == request.auth.uid;
        }

        function validDeliveryChatMessage() {
          return request.resource.data.keys().hasOnly(["authorUid", "body", "createdAt"]) &&
            request.resource.data.authorUid == request.auth.uid &&
            request.resource.data.authorUid is string &&
            request.resource.data.body is string &&
            request.resource.data.body.size() > 0 &&
            request.resource.data.body.size() <= 2000 &&
            request.resource.data.createdAt == request.time;
        }

        allow read: if isAuthed() && (
          hasAnyRole(["manager", "admin", "cashier"]) ||
          deliveryThreadParticipant() ||
          deliveryCustomerOwnsOrder(deliveryId)
        );
        allow create: if isAuthed() && validDeliveryChatMessage() && (
          (
            hasAnyRole(["delivery_boy", "delivery"]) &&
            staffUserActive() &&
            deliveryThreadParticipant()
          ) ||
          deliveryCustomerOwnsOrder(deliveryId)
        );
        allow update, delete: if false;
      }
    }

    match /printers/{printerId} {
      allow read: if staffUserActive() && hasAnyRole(["kitchen", "kitchen_staff", "cashier", "waiter", "manager", "admin"]);
      allow create: if staffUserActive() && hasAnyRole(["manager", "admin"]) && validPrinterCreate();
      allow update: if staffUserActive() && hasAnyRole(["manager", "admin"]) && validPrinterUpdate();
      allow delete: if staffUserActive() && hasAnyRole(["manager", "admin"]);
    }

    match /settings/{id} {
      allow read: if hasAnyRole(["manager", "admin"]);
      allow write: if hasRole("admin") &&
        hasOnlyKeys(["id", "storeName", "currency", "timezone", "businessHours", "deliveryRadiusKm", "taxPercent", "discountPercent", "updatedAt", "createdAt"]);
    }

    // Mirrors / sync collections (written by Admin SDK or Cloud Functions only)
    match /orderFeeds/{orderId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /deliveryTracking/{orderId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    /**
     * Live rider GPS for an order (`deliveryLocations/{orderId}`).
     * Read: any signed-in client (customers see rider on order tracker when logged in).
     * Write: assigned rider / managers — optional `riderName`, `riderMobile` for customer UI.
     */
    match /deliveryLocations/{orderId} {
      allow read: if isAuthed();
      allow create: if hasAnyRole(["delivery_boy", "delivery", "manager", "admin"]) &&
        staffUserActive() &&
        request.resource.data.keys().hasOnly([
          "orderId",
          "userId",
          "lat",
          "lng",
          "updatedAt",
          "riderName",
          "riderMobile",
          "etaMinutes"
        ]) &&
        request.resource.data.orderId == orderId &&
        request.resource.data.userId is string &&
        request.resource.data.lat is number &&
        request.resource.data.lng is number &&
        request.resource.data.updatedAt == request.time &&
        (
          !request.resource.data.keys().hasAny(["riderName"]) ||
          request.resource.data.riderName is string
        ) &&
        (
          !request.resource.data.keys().hasAny(["riderMobile"]) ||
          request.resource.data.riderMobile is string
        ) &&
        (
          !request.resource.data.keys().hasAny(["etaMinutes"]) ||
          (request.resource.data.etaMinutes is int && request.resource.data.etaMinutes >= 0)
        );
      allow update: if hasAnyRole(["delivery_boy", "delivery", "manager", "admin"]) &&
        staffUserActive() &&
        request.resource.data.orderId == orderId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "lat",
          "lng",
          "updatedAt",
          "riderName",
          "riderMobile",
          "etaMinutes"
        ]) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.lat is number &&
        request.resource.data.lng is number;
    }

    match /customerOrderNotifications/{id} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /staffNewOrderEvents/{id} {
      allow read: if hasAnyRole(["kitchen_staff", "waiter", "cashier", "manager", "admin", "delivery_boy", "delivery"]);
      allow write: if false;
    }

    /** Floor plan: waiter + cashier read; managers/admins maintain; waiter/cashier may patch `status`. */
    match /tables/{tableId} {
      allow read: if staffUserActive() && hasAnyRole(["waiter", "cashier", "manager", "admin"]);
      allow create, delete: if staffUserActive() && hasAnyRole(["manager", "admin"]);
      allow update: if (staffUserActive() && hasAnyRole(["manager", "admin"])) ||
        (staffUserActive() && hasRole("waiter") &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "currentOrderId"]) &&
          request.resource.data.status in ["OCCUPIED", "FREE", "free", "occupied"] &&
          (
            !request.resource.data.keys().hasAny(["currentOrderId"]) ||
            request.resource.data.currentOrderId == null ||
            request.resource.data.currentOrderId is string
          )) ||
        (staffUserActive() && hasRole("cashier") &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(["status"]) &&
          request.resource.data.status in ["FREE", "free"]);
    }

    match /adminAlerts/{docId} {
      allow read: if hasRole("admin");
      allow write: if false;
    }

    match /rateLimits/{id} {
      allow read, write: if false;
    }

    match /idempotency/{id} {
      allow read, write: if false;
    }

    // Customer reviews (writes via Admin SDK / Next API only)
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
