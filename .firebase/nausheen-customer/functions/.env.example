# Client Firebase (nausheen-fruits-new) — copy to .env.local
# authDomain MUST be <projectId>.firebaseapp.com — never a custom brand domain
# unless Firebase Custom Auth Domain is explicitly configured.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nausheen-fruits-new.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nausheen-fruits-new
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nausheen-fruits-new.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=611343650554
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server Admin SDK (same project)
# Do NOT use FIREBASE_* names — Firebase Hosting frameworks rejects that prefix.
ADMIN_SDK_PROJECT_ID=nausheen-fruits-new
ADMIN_SDK_CLIENT_EMAIL=
ADMIN_SDK_PRIVATE_KEY=

# Optional
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
