<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F8FAFC">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Analytics Dashboard"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:paddingBottom="8dp" />

    <ProgressBar
        android:id="@+id/analyticsLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Orders Today"
                android:textColor="#64748B"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/metricTotalOrdersToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginStart="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Revenue"
                android:textColor="#64748B"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/metricTotalRevenue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rs. 0"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:textSize="24sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pending Orders"
                android:textColor="#64748B"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/metricPendingOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:textSize="24sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginStart="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delivered Orders"
                android:textColor="#64748B"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/metricDeliveredOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:textSize="24sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginTop="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Orders Per Hour"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/emptyChartText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No orders today."
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/ordersPerHourBars"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="bottom" />
        </HorizontalScrollView>
    </LinearLayout>

</LinearLayout>
