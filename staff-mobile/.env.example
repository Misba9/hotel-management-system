# Copy this file to `.env` in this folder (staff-mobile root, next to package.json).
# Paste values from Firebase Console → Project settings → Your apps → Web app (Expo JS SDK).
#
# MUST match native: google-services.json → project_info.project_id must equal EXPO_PUBLIC_FIREBASE_PROJECT_ID.
# Also keep src/config/firebase-project-lock.js in sync with that project_id (dev-time mismatch warning).
# If Firestore logs exists: false but Console shows the doc → wrong project in .env — fix and: npx expo start -c
#
# If Auth says "API key not valid": Google Cloud → Credentials → that key → restrictions None, wait 2–5 min, restart.
# Rules: no quotes, no spaces around `=`, exact values.

# Example (must match google-services.json project_info for the same project):
# EXPO_PUBLIC_FIREBASE_API_KEY=...
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=nausheen-fruits-new.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=nausheen-fruits-new
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=nausheen-fruits-new.firebasestorage.app
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=611343650554
# EXPO_PUBLIC_FIREBASE_APP_ID=1:611343650554:web:... (Web app preferred) or Android mobilesdk_app_id from google-services.json
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional (Analytics):
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
