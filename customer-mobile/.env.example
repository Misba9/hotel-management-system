# Customer-web API base (checkout, coupons, SMS OTP, cart sync)
# On a physical phone, use your computer's LAN IP — NOT localhost.
# SMS OTP requires customer-web env: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_SMS_FROM
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.104:3000

# Google uses Firebase AuthSession (no local server). Apple fallback bridge must be HTTPS:
