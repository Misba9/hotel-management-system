{
  "expo": {
    "name": "Nausheen Fruits",
    "slug": "nausheen-customer",
    "scheme": "nausheen-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/customer-mobile-logo.png",
    "splash": {
      "image": "./assets/customer-mobile-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1f2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "androidMode": "default",
          "androidCollapsedTitle": "Nausheen Fruits"
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hotel.customerapp",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.hotel.customermobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/customer-mobile-logo.png",
        "backgroundColor": "#1a1f2e"
      },
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
