{
  "name": "nausheen-fruits-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "customer-web",
    "staff-mobile",
    "backend/functions"
  ],
  "overrides": {
    "react-native": "0.74.5"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "razorpay": "^2.9.6",
    "react-firebase-hooks": "^5.1.1",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "esModuleInterop": true,
      "resolveJsonModule": true
    }
  },
  "scripts": {
    "clean:next": "rm -rf .next admin-dashboard/.next customer-web/.next",
    "dev": "node -e \"console.log('\\n  Apps (each serves its own /_next/static — stay on the matching origin):\\n  customer-web    → http://localhost:3000\\n  admin-dashboard → http://localhost:3001\\n  staff-mobile    → http://localhost:3002\\n')\" && npm run dev --prefix customer-web & npm run dev --prefix admin-dashboard & npm run dev --prefix staff-mobile -- --web --port 3002 & wait",
    "dev:customer": "npm run dev --workspace @nausheen/customer-web",
    "dev:admin": "npm run dev --workspace @nausheen/admin-dashboard",
    "dev:mobile": "npm run start --workspace @nausheen/staff-mobile",
    "build:web": "npm run build --workspace @nausheen/customer-web && npm run build --workspace @nausheen/admin-dashboard",
    "build:functions": "npm run build --workspace @nausheen/functions",
    "deploy": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only hosting",
    "deploy:functions": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only functions",
    "deploy:hosting": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only hosting",
    "deploy:rules": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only firestore:rules,storage",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "set-admin-role": "ts-node --project scripts/tsconfig.json scripts/set-admin-role.ts",
    "seed:dummy-orders": "node scripts/seed-dummy-orders.mjs"
  }
}
