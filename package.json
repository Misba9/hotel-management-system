{
  "name": "nausheen-fruits-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "customer-web",
    "staff-mobile",
    "backend/functions"
  ],
  "overrides": {
    "react-native": "0.74.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "razorpay": "^2.9.6",
    "react-firebase-hooks": "^5.1.1",
    "typescript": "^5.1.6"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "esModuleInterop": true,
      "resolveJsonModule": true
    }
  },
  "scripts": {
    "build": "npm run build --prefix customer-web",
    "start": "npm run start --prefix customer-web",
    "lint": "npm run lint --prefix customer-web",
    "clean:next": "rm -rf .next admin-dashboard/.next customer-web/.next",
    "clean:install": "rm -rf node_modules admin-dashboard/node_modules customer-web/node_modules staff-mobile/node_modules backend/functions/node_modules admin-dashboard/.next customer-web/.next .next && npm install",
    "clean:install:fresh": "rm -rf node_modules admin-dashboard/node_modules customer-web/node_modules staff-mobile/node_modules backend/functions/node_modules package-lock.json admin-dashboard/.next customer-web/.next .next && npm install",
    "free:ports": "PORTS_TO_FREE=3000,3001 node customer-web/scripts/free-dev-port.mjs",
    "free:ports:dev": "PORTS_TO_FREE=3000,3001,3002,3003,8081 node customer-web/scripts/free-dev-port.mjs",
    "recover:customer": "npm run free:ports && npm run clean:next && npm run recover:chunks -w @nausheen/customer-web",
    "staff": "npm run dev --workspace=staff-mobile",
    "dev": "concurrently -n WEB,ADMIN,MOBILE -c blue,green,yellow \"npm run dev:web\" \"npm run dev:admin\" \"npm run dev:mobile\"",
    "dev:all": "node -e \"console.log('\\n  For unmixed logs, run in separate terminals:\\n    npm run dev:web\\n    npm run dev:admin\\n    npm run dev:mobile\\n\\n  URLs: http://localhost:3000 (web), http://localhost:3001 (admin), Expo Metro (default 8081)\\n')\"",
    "dev:web": "npm run dev --workspace=customer-web",
    "dev:admin": "npm run dev --workspace=admin-dashboard",
    "dev:mobile": "npm run dev --workspace=staff-mobile",
    "dev:customer": "npm run dev:web",
    "build:web": "npm run build --workspace @nausheen/customer-web && npm run build --workspace @nausheen/admin-dashboard",
    "build:functions": "npm run build --workspace @nausheen/functions",
    "firebase:build": "npm run build:functions",
    "firebase:deploy:functions": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only functions",
    "firebase:deploy:hosting": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only hosting",
    "firebase:deploy:rules": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only firestore:rules,storage",
    "firebase:deploy:firestore": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only firestore",
    "firebase:deploy:all": "firebase deploy --config backend/firebase.json --project nausheen-fruits",
    "firebase:release:functions": "npm run firebase:build && npm run firebase:deploy:functions",
    "deploy": "firebase deploy --config backend/firebase.json --project nausheen-fruits --only hosting",
    "deploy:functions": "npm run firebase:deploy:functions",
    "deploy:hosting": "npm run firebase:deploy:hosting",
    "deploy:rules": "npm run firebase:deploy:rules",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "set-admin-role": "ts-node --project scripts/tsconfig.json scripts/set-admin-role.ts",
    "seed:dummy-orders": "node scripts/seed-dummy-orders.mjs"
  }
}
