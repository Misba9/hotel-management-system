{
  "name": "@nausheen/staff-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "author": "Nausheen Fruits",
  "description": "Staff desktop app for cashier, kitchen, and manager operations",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5177 dist-electron/electron/main.js && electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:electron && vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "rebuild:native": "electron-rebuild -f -w sqlite3,serialport",
    "dist:win": "npm run rebuild:native && npm run build && electron-builder --win --x64",
    "dist": "npm run dist:win"
  },
  "build": {
    "appId": "com.nausheen.staff-desktop",
    "productName": "Nausheen Staff",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite3/**",
      "**/node_modules/serialport/**",
      "**/node_modules/@serialport/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nausheen Staff"
    }
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "dotenv": "^16.4.5",
    "firebase": "^11.1.0",
    "lucide-react": "^0.453.0",
    "node-thermal-printer": "^4.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "serialport": "^12.0.0",
    "sqlite3": "^5.1.7",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
